# ── Database Backend ──────────────────────────────────────
# Choose ONE of: "sqlite" (local, default) or "postgres" (Supabase)
# If DATABASE_URL starts with postgres:// it is auto-detected, but explicit is safer.
# EG_DB_BACKEND=sqlite
EG_DB_BACKEND=postgres

# ── SQLite Mode (local) ──────────────────────────────────
# Only used when EG_DB_BACKEND=sqlite
EG_DATA_DIR=/data
EG_DB_PATH=/data/sqlite/echogarden.db

# ── Supabase / Postgres Mode ─────────────────────────────
# Find these values in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct DB connection (find in: Dashboard → Settings → Database → Connection string)
# IMPORTANT: Always include ?sslmode=require for Supabase
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# ── Qdrant (vector search) ───────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── Tika (document parsing) ─────────────────────────────
TIKA_URL=http://tika:9998

# ── Model paths (cached under /data/models) ─────────────
EG_MODELS_DIR=/data/models

# ── Whisper mode: local | stub ───────────────────────────
# Use "stub" to skip Whisper model download during development
EG_WHISPER_MODE=local

# ── OpenCLIP mode: local | stub ──────────────────────────
# Use "stub" to skip OpenCLIP model download during development
EG_OPENCLIP_MODE=local

# ── Browser Capture API Key ──────────────────────────────
# Required for /capture/browser/* endpoints. Set a strong secret.
EG_CAPTURE_API_KEY=changeme-to-a-strong-secret

# ── Host Folder Capture ──────────────────────────────────
# Absolute path to a folder on your computer that will be watched for new files.
# macOS/Linux example:  /Users/me/echogarden_watch
# Windows example:      C:/Users/me/echogarden_watch
EG_HOST_WATCH_PATH=/absolute/path/on/host

# Polling interval in seconds (default: 2)
# EG_POLL_INTERVAL=2

# Max file size in MB — larger files get a placeholder card (default: 20)
# EG_MAX_FILE_MB=20

# ── Institutional defaults for watcher-triggered ingest ──
EG_DEFAULT_INSTITUTION_ID=00000000-0000-0000-0000-000000000000
EG_DEFAULT_PERIOD=unspecified

# ── CORS (for cloud deployment) ──────────────────────────
# Comma-separated list of allowed origins for the API.
# Add your deployed frontend URL here.
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-app.vercel.app

# ── LLM Provider (cloud + local fallback) ─────────────────
# auto | gemini | openai | groq | anthropic | ollama
EG_LLM_PROVIDER=auto

# Gemini
GEMINI_API_KEY=
EG_GEMINI_MODEL=gemini-2.5-flash

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
EG_OPENAI_MODEL=gpt-4o-mini

# Groq (OpenAI-compatible API)
GROQ_API_KEY=
EG_GROQ_BASE_URL=https://api.groq.com/openai/v1
EG_GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic
ANTHROPIC_API_KEY=
EG_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
EG_ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Local Ollama fallback (used when selected or when auto falls back)
EG_OLLAMA_URL=http://host.docker.internal:11434
EG_OLLAMA_MODEL=phi3:mini
EG_OLLAMA_TIMEOUT=180
